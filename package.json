{
    "name": "myde-dbus",
    "version": "0.3.2",
    "type": "module",
    "repository": {
        "url": "https://github.com/xushengfeng/node-dbus"
    },
    "keywords": [
        "dbus"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && vite build",
        "test": "vitest run"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.5",
        "myde-unix-socket": "^0.2.2",
        "typescript": "~6.0.3",
        "vite": "^8.0.1",
        "vite-plugin-dts": "^5.0.0",
        "vitest": "^4.1.1"
    }
}
