{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src"
  ]
}